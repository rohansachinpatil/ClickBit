# ClickBit Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Mistral AI ────────────────────────────────────────────────────────────────
MISTRAL_API_KEY=your_mistral_api_key_here

# Optional: override the default model
# MISTRAL_MODEL=mistral-small-latest

# ── Browser Configuration ───────────────────────────────────────────────────
# Path to your browser executable (e.g. Comet or Chrome)
# BROWSER_PATH=C:\Path\To\Comet\browser.exe

# Remote debugging URL (default is http://localhost:9222)
# BROWSER_REMOTE_URL=http://localhost:9222
